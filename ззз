    }

    .section-content img {
      width: 100%;
      border-radius: 10px;
      border: 1px solid rgba(255,255,255,0.25);
      box-shadow: 0 0 25px black;
    }

    .section-content p {
      font-size: 18px;
      line-height: 1.7;
