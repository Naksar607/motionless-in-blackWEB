  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      min-height: 100vh;
      font-family: Georgia, serif;
      background:
        linear-gradient(rgba(0,0,0,0.65), rgba(0,0,0,0.95)),
        url("photo4.png");
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      color: white;
      padding: 30px;
    }

    .back {
      position: fixed;
      top: 20px;
      left: 20px;
      color: white;
      text-decoration: none;
      border: 1px solid red;
      padding: 10px 20px;
      background: rgba(0,0,0,0.75);
      border-radius: 6px;
      z-index: 10;
    }

    .back:hover {
      background: red;
      color: black;
    }

    .container {
      max-width: 1100px;
      margin: 80px auto;
      background: rgba(0,0,0,0.75);
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 14px;
      backdrop-filter: blur(6px);
      box-shadow: 0 0 40px black;
      padding: 40px;
    }

    h1 {
      text-align: center;
      font-size: 64px;
      color: #b80000;
      text-transform: uppercase;
      letter-spacing: 6px;
      margin-bottom: 30px;
      text-shadow: 0 0 25px black;
    }

    .main-info {
      font-size: 20px;
      line-height: 1.7;
